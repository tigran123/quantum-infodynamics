# "development" enables uvicorn --reload. Anything else (or unset) means prod.
APP_ENV="development"

# SPA mount point. Drives both uvicorn --root-path and Vite base.
# Dev: leave unset (defaults to /). Prod: /wignerf (matches the nginx prefix).
APP_ROOT_PATH="/"

WIGNERF_MAX_GRID=8192

WIGNERF_HISTORY_MB=65536
